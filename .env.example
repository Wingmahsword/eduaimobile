# ── Supabase (required for auth + database) ─────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CMS server (reels backend) ───────────────────────────────────────────────
# Local dev
EXPO_PUBLIC_CMS_BASE_URL=http://localhost:4100
# Production (Render URL — set after deploying cms-server)
# EXPO_PUBLIC_CMS_BASE_URL=https://eduai-cms-api.onrender.com

# CMS server environment
CMS_PORT=4100
CMS_ADMIN_TOKEN=eduai-local-admin
