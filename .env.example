# ── Supabase (required for auth + database) ─────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── CMS server (reels backend) ───────────────────────────────────────────────
# Local dev
EXPO_PUBLIC_CMS_BASE_URL=http://localhost:4100
# Production — set this in Vercel after CMS is deployed to Render
# EXPO_PUBLIC_CMS_BASE_URL=https://eduai-cms-api.onrender.com

# CMS server — local .env (create cms-server/.env for local dev)
CMS_PORT=4100
CMS_ADMIN_TOKEN=eduai-local-admin

# These go in cms-server/.env (NOT the root .env.local)
# Get from: supabase.com → your project → Settings → API → Service role key
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -- AI Playground (OpenRouter proxy) -----------------------------------------
# Server-side ONLY. Set in Vercel -> Project -> Settings -> Environment Variables.
# Get a free key: https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: shown in OpenRouter dashboard as the app origin
OPENROUTER_SITE_URL=https://eduai-mobile.vercel.app
OPENROUTER_APP_NAME=EduAI Mobile

# -- Optional client override (rare) ------------------------------------------
# If you host /api/chat on a different deployment, override here.
# EXPO_PUBLIC_API_BASE_URL=https://eduai-mobile.vercel.app
