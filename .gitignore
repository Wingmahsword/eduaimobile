# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/
cms-server/node_modules/
# allow pre-built dist assets (fonts live under dist/assets/node_modules/...)
!dist/
!dist/**

# Expo
.expo/
web-build/
# dist/ is intentionally committed for Vercel static deployment
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# local debug artifacts
cms.log

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
